generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model CmsMasterData {
  id         String   @id @default(uuid())
  key        String   @unique
  config     Json
  updated_at DateTime @default(now())

  @@map("cms_master_data")
}

model CmsProject {
  id           String   @id @default(uuid())
  client_name  String
  project_name String
  total_cost   Decimal  @db.Decimal(15, 2)
  data         Json
  created_at   DateTime @default(now())

  @@map("cms_projects")
}
